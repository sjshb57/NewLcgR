<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    framework 模块此前定义了一份与 app 完全重复的 AppTheme / SplashTheme / Toolbar /
    TextStyle.* / Button / AppTab / BottomInOutAnim 等 styles，且 colorPrimary 等关键值
    与 app 取值矛盾，靠资源合并顺序决定胜出，是潜在 bug 源。

    现把所有"应用层"概念的 styles 收口到 app/values/styles.xml；framework 不再定义。
    framework 自己的 layout 不引用 @style/*，确认安全。
    -->
</resources>
