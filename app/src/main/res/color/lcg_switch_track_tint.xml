<?xml version="1.0" encoding="utf-8"?>
<!--
  SwitchMaterial 轨道（条形）的着色：
  - checked: pojie_logo 红的半透明（视觉上比纯红浅一点，避免太刺眼）
  - 默认（unchecked）: 浅灰（还原 MD2 风格的 off-state）
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="@color/pojie_logo_light" />
    <item android:color="@color/light_gray" />
</selector>
