<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout"
    style="@style/Widget.LCG.ItemCard">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/article_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/dp_12"
        android:paddingBottom="@dimen/dp_12">

        <TextView
            android:id="@+id/title_text_view"
            style="@style/TextStyle.Heading"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_14"
            android:layout_marginEnd="@dimen/dp_14"
            android:maxLines="2"
            android:textSize="@dimen/sp_16"
            android:lineSpacingExtra="@dimen/dp_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Title"/>

        <TextView
            android:id="@+id/reply_and_view"
            style="@style/TextStyle.Title.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_8"
            app:layout_constraintTop_toBottomOf="@id/title_text_view"
            app:layout_constraintStart_toStartOf="@id/title_text_view"
            tools:text="10 / 200"/>

        <TextView
            android:id="@+id/origin"
            style="@style/TextStyle.Title.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:maxWidth="@dimen/dp_200"
            android:singleLine="true"
            android:layout_marginStart="@dimen/dp_8"
            app:layout_constraintTop_toTopOf="@id/reply_and_view"
            app:layout_constraintBottom_toBottomOf="@id/reply_and_view"
            app:layout_constraintStart_toEndOf="@id/reply_and_view"
            tools:text="『原创发布区』"/>

        <top.easelink.framework.customview.ELStampView
            android:id="@+id/stamp"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_8"
            android:layout_marginTop="@dimen/dp_4"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible"
            tools:stampText="50"
            tools:stampColor="@color/colorAccent"
            />

        <TextView
            android:id="@+id/author_text_view"
            style="@style/TextStyle.Title.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dp_8"
            app:layout_constraintTop_toTopOf="@id/reply_and_view"
            app:layout_constraintBottom_toBottomOf="@id/reply_and_view"
            app:layout_constraintEnd_toEndOf="@id/title_text_view"
            tools:text="Author"/>

        <TextView
            android:id="@+id/date_text_view"
            style="@style/TextStyle.Title.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_4"
            app:layout_constraintTop_toBottomOf="@id/author_text_view"
            app:layout_constraintEnd_toEndOf="@id/title_text_view"
            tools:text="2019-07-04"/>

        <ImageView
            android:id="@+id/recommend_flag"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:src="@drawable/ic_recommendation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@null" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
