<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/article_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:paddingStart="@dimen/dp_12"
    android:paddingEnd="@dimen/dp_12"
    android:paddingTop="@dimen/dp_10"
    android:paddingBottom="@dimen/dp_10"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/index"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/dp_6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title_text_view"
        app:layout_constraintBottom_toBottomOf="@id/title_text_view"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/title_text_view"
        style="@style/TextStyle.Heading"
        android:textStyle="bold"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:textSize="@dimen/sp_14"
        android:lineSpacingExtra="@dimen/dp_2"
        app:layout_constraintStart_toEndOf="@id/index"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Today Hot title example text"/>

    <TextView
        android:id="@+id/forum"
        style="@style/TextStyle.Title.Sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="middle"
        android:maxWidth="@dimen/dp_200"
        android:singleLine="true"
        android:layout_marginTop="@dimen/dp_6"
        app:layout_constraintTop_toBottomOf="@id/title_text_view"
        app:layout_constraintStart_toStartOf="@id/title_text_view"
        tools:text="『原创发布区』"/>

    <TextView
        android:id="@+id/num"
        style="@style/TextStyle.Title.Sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minEms="4"
        android:gravity="end"
        android:layout_marginStart="@dimen/dp_8"
        app:layout_constraintTop_toTopOf="@id/forum"
        app:layout_constraintBottom_toBottomOf="@id/forum"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/red_dark2"
        tools:text="热度:233"/>

</androidx.constraintlayout.widget.ConstraintLayout>
