<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@drawable/launch_bg</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
    </style>

    <style name="NoAnimation">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:taskOpenEnterAnimation">@null</item>
        <item name="android:taskCloseEnterAnimation">@null</item>
        <item name="android:taskToFrontEnterAnimation">@null</item>
        <item name="android:taskToBackEnterAnimation">@null</item>
    </style>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/lcg_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/lcg_on_primary_container</item>

        <item name="colorSecondary">@color/pojie_logo</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/lcg_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/pojie_logo</item>

        <item name="colorTertiary">@color/lcg_tertiary</item>
        <item name="colorOnTertiary">@color/lcg_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/lcg_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/lcg_on_tertiary_container</item>

        <item name="colorError">@color/lcg_error</item>
        <item name="colorOnError">@color/lcg_on_error</item>
        <item name="colorErrorContainer">@color/lcg_error_container</item>
        <item name="colorOnErrorContainer">@color/lcg_on_error_container</item>

        <item name="colorSurface">@color/lcg_surface</item>
        <item name="colorOnSurface">@color/lcg_on_surface</item>
        <item name="colorSurfaceVariant">@color/lcg_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/lcg_on_surface_variant</item>
        <item name="android:colorBackground">@color/lcg_background</item>
        <item name="colorOnBackground">@color/lcg_on_surface</item>

        <item name="colorOutline">@color/lcg_outline</item>
        <item name="colorOutlineVariant">@color/lcg_outline_variant</item>

        <item name="android:textColorPrimary">@color/lcg_on_surface</item>
        <item name="android:textColorSecondary">@color/lcg_on_surface_variant</item>

        <item name="android:windowBackground">@color/lcg_surface</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/sp_16</item>
        <item name="android:typeface">sans</item>

        <item name="drawerArrowStyle">@style/MaterialDrawer.DrawerArrowStyle</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_arrow_back_black_24px</item>
        <item name="actionOverflowButtonStyle">@style/LCGOverflowButtonStyle</item>
        <item name="searchViewStyle">@style/LCGSearchView</item>

        <item name="toolbarStyle">@style/AppToolbarStyle</item>

        <item name="switchStyle">@style/Widget.LCG.Switch</item>
        <item name="materialSwitchStyle">@style/Widget.LCG.MaterialSwitch</item>

        <item name="bottomNavigationStyle">@style/Widget.LCG.BottomNavigationView</item>
    </style>

    <style name="AppToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/lcg_surface</item>
        <item name="titleTextColor">@color/lcg_on_surface</item>
        <item name="subtitleTextColor">@color/lcg_on_surface_variant</item>
        <item name="navigationIconTint">@color/lcg_on_surface</item>
        <item name="actionMenuTextColor">@color/lcg_on_surface</item>
        <item name="actionOverflowButtonStyle">@style/LCGOverflowButtonStyle.Black</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="LCGOverflowButtonStyle.Black" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/lcg_on_surface</item>
    </style>

    <style name="Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/actionBarSize</item>
        <item name="android:background">@color/lcg_surface</item>
        <item name="colorControlNormal">@color/lcg_on_surface</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="titleTextColor">@color/lcg_on_surface</item>
    </style>

    <style name="Toolbar.TitleText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/lcg_on_surface</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="AppTheme.Dialog.FullScreen.BottomInOut" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/lcg_surface</item>
        <item name="android:windowAnimationStyle">@style/BottomInOutAnim</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="LCGOverflowButtonStyle" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/lcg_on_surface</item>
    </style>

    <style name="MaterialDrawer.DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="spinBars">false</item>
        <item name="color">@color/lcg_on_surface</item>
    </style>

    <style name="LCGSearchView" parent="Widget.AppCompat.SearchView">
        <item name="defaultQueryHint">@string/input_key_word</item>
        <item name="queryBackground">@color/lcg_surface</item>
        <item name="submitBackground">@color/lcg_surface</item>
    </style>

    <style name="TextStyle">
        <item name="android:layout_marginTop">@dimen/dp_2</item>
        <item name="android:layout_marginBottom">@dimen/dp_2</item>
        <item name="android:layout_marginLeft">@dimen/dp_2</item>
        <item name="android:layout_marginRight">@dimen/dp_2</item>
        <item name="android:textColor">@color/lcg_on_surface</item>
    </style>

    <style name="TextStyle.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/lcg_on_surface</item>
    </style>

    <style name="TextStyle.Title.Sub" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">@dimen/sp_12</item>
        <item name="android:textColor">@color/lcg_on_surface_variant</item>
    </style>

    <style name="TextStyle.Heading" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/sp_16</item>
        <item name="android:textColor">@color/lcg_on_surface</item>
    </style>

    <style name="TextStyle.SearchResult.Abstract" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/sp_12</item>
        <item name="android:textColor">@color/lcg_on_surface_variant</item>
    </style>

    <style name="TextStyle.SearchResult.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/sp_14</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/lcg_on_surface</item>
    </style>

    <style name="CollapsingToolbar.TitleText" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/lcg_on_surface</item>
        <item name="android:textSize">@dimen/sp_16</item>
    </style>

    <style name="Button" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/lcg_on_surface</item>
        <item name="android:layout_height">@dimen/dp_48</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:paddingLeft">@dimen/dp_8</item>
        <item name="android:paddingRight">@dimen/dp_8</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/dp_16</item>
        <item name="android:background">@drawable/button_bg</item>
        <item name="android:foreground">?selectableItemBackground</item>
    </style>

    <style name="Button.Action.Positive" parent="Button">
        <item name="android:textColor">@drawable/button_positive_text_drawable</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">@dimen/sp_16</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="Button.Action.Negative" parent="Button">
        <item name="android:textColor">@drawable/button_negative_text_drawable</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">@dimen/dp_16</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="AppTab" parent="Widget.Material3.TabLayout">
        <item name="android:minHeight">?attr/actionBarSize</item>
        <item name="tabTextAppearance">@style/AppTab.TextAppearance</item>
        <item name="tabIndicatorHeight">@dimen/dp_2</item>
        <item name="tabSelectedTextColor">@color/lcg_on_surface</item>
        <item name="tabTextColor">@color/lcg_on_surface_variant</item>
    </style>

    <style name="AppTab.TextAppearance" parent="TextAppearance.Material3.LabelLarge">
        <item name="textAllCaps">false</item>
        <item name="android:textSize">@dimen/sp_14</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ReplyEditText" parent="Theme.Material3.DayNight">
        <item name="colorControlNormal">@color/lcg_on_surface_variant</item>
        <item name="colorControlActivated">@color/pojie_logo</item>
    </style>

    <style name="Widget.LCG.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.LCG.BottomNavigationView.ActiveIndicator</item>
        <item name="itemTextAppearanceActive">@style/Widget.LCG.BottomNavigationView.Label</item>
        <item name="itemTextAppearanceInactive">@style/Widget.LCG.BottomNavigationView.Label</item>
        <item name="itemTextColor">@color/bottom_nav_state</item>
        <item name="itemIconTint">@color/bottom_nav_state</item>
        <item name="itemRippleColor">@color/translucent_gray</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.LCG.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="Widget.LCG.BottomNavigationView.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.Dialog.FullScreen" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
    </style>

    <style name="BottomInOutAnim" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>

    <style name="FadeInOutAnim" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
    </style>

    <style name="Widget.LCG.ItemCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/dp_12</item>
        <item name="android:layout_marginEnd">@dimen/dp_12</item>
        <item name="android:layout_marginTop">@dimen/dp_4</item>
        <item name="android:layout_marginBottom">@dimen/dp_4</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cardCornerRadius">@dimen/dp_10</item>
        <item name="cardElevation">@dimen/dp_1</item>
        <item name="cardBackgroundColor">@color/lcg_surface</item>
    </style>

    <style name="Widget.LCG.Switch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="thumbTint">@color/lcg_switch_thumb_tint</item>
        <item name="trackTint">@color/lcg_switch_track_tint</item>
    </style>

    <style name="Widget.LCG.MaterialSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/lcg_switch_thumb_tint</item>
        <item name="trackTint">@color/lcg_switch_track_tint</item>
        <item name="trackDecorationTint">@color/lcg_switch_track_tint</item>
    </style>

</resources>
